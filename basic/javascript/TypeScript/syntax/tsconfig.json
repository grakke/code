{
    // "files": [],
    "compilerOptions": {
        "module": "commonjs",
        // "outFile": "",
        "target": "es2021",
        "noImplicitAny": true, // 在表达式和声明上有隐含的'any'类型时报错, 最好之后改成true
        "sourceMap": true,
        "outDir": "./dist", // 输出目录
        "baseUrl": ".",
        "paths": {
            "*": ["node_modules/*"]
        }
    },
    "include": ["src/**/*"]
}
